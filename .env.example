# ============================================================
# Immich Docker Compose — Environment Configuration
# ============================================================
# Documentation: https://docs.immich.app/install/environment-variables
# Copy this file:  cp .env.example .env
# Then edit .env with your actual values.

# ── Storage Locations ──────────────────────────────────────
# Host path where uploaded photos/videos are stored
UPLOAD_LOCATION=./library

# Host path where PostgreSQL database files are stored
# WARNING: Must be on local disk — NFS/network shares cause corruption
DB_DATA_LOCATION=./postgres

# ── Immich Version ─────────────────────────────────────────
# Pin to a specific version (e.g., v2.5.6) or use v2 for latest v2.x
IMMICH_VERSION=v2

# ── Timezone ───────────────────────────────────────────────
# TZ identifier: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Taipei

# ── Server Port ────────────────────────────────────────────
# Host port mapped to Immich web UI (container always uses 2283)
IMMICH_PORT=2283

# ── PostgreSQL Credentials ─────────────────────────────────
# Use only A-Za-z0-9 characters — no special characters or spaces
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# ── Machine Learning (Optional) ───────────────────────────
# MACHINE_LEARNING_WORKERS=1
# MACHINE_LEARNING_MODEL_TTL=300
